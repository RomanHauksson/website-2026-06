---
import { Icon } from "astro-icon/components";
---

<canvas class="block w-full h-auto aspect-square hover:cursor-grab active:cursor-grabbing" id="splat-canvas"></canvas>
<Icon class="mx-auto text-gray-700 dark:text-gray-300 mb-10" size={40} name="hugeicons:drag-03" />


<script>
import * as THREE from "three";
import { OrbitControls } from "three/addons/controls/OrbitControls.js";
import { SparkRenderer, SplatMesh } from "@sparkjsdev/spark";
const scene = new THREE.Scene();
const canvas = document.getElementById("splat-canvas") as HTMLCanvasElement;
const camera = new THREE.PerspectiveCamera(
	60,
	canvas.clientWidth / canvas.clientHeight,
	0.01,
	1000,
);
const renderer = new THREE.WebGLRenderer({ canvas, alpha: true });
renderer.setClearColor(0x000000, 0);

function resize() {
	const width = canvas.clientWidth;
	const height = canvas.clientHeight;
	renderer.setPixelRatio(window.devicePixelRatio);
	renderer.setSize(width, height, false);
	camera.aspect = width / height;
	camera.updateProjectionMatrix();
}
resize();
window.addEventListener("resize", resize);

const spark = new SparkRenderer({ renderer });
scene.add(spark);

const splatURL = "/Roman.sog";
const roman = new SplatMesh({ url: splatURL });
roman.quaternion.set(1, 0, 0, 0);
roman.position.set(0, 0, -1.8);
scene.add(roman);

// Raise the camera and aim it at the model.
camera.position.set(0, 0.7, 0);
camera.lookAt(roman.position);

// Let the user click/drag (or touch/drag) to orbit the camera around the
// model. OrbitControls is the approach recommended by Spark's docs and
// examples, since SplatMesh is a regular THREE.Object3D.
const controls = new OrbitControls(camera, renderer.domElement);
controls.target.copy(roman.position);
controls.enableDamping = true; // smooth, weighted feel with momentum
controls.enablePan = false; // dragging only rotates, never slides the model away
controls.enableZoom = false; // keep the framing fixed and let the page scroll
controls.update();

// The figure may never be seen from more than this far off its front, so the
// user can't spin around to the back.
const FRONT_LIMIT = Math.PI / 2; // 90 degrees

// Idle animation: rotate back and forth around the vertical axis between -45
// and 45 degrees. A sine drives the angle, easing the motion at each extreme.
const baseQuat = roman.quaternion.clone();
const yAxis = new THREE.Vector3(0, 1, 0);
const swingQuat = new THREE.Quaternion();
const clock = new THREE.Clock();

const MAX_ANGLE = Math.PI / 4; // 45 degrees: how far the idle swing turns
const SPEED = 1; // radians per second of the driving sine

let hasInteracted = false;
let swingAngle = 0; // the body's current rotation away from facing front

// The first drag stops the idle swing for good and locks the camera orbit
// around wherever the body froze, so the user can still see the front and
// sides but never spin around to the back.
controls.addEventListener("start", () => {
	hasInteracted = true;
	controls.minAzimuthAngle = swingAngle - FRONT_LIMIT;
	controls.maxAzimuthAngle = swingAngle + FRONT_LIMIT;
});

renderer.setAnimationLoop(function animate() {
	if (!hasInteracted) {
		swingAngle = MAX_ANGLE * Math.sin(clock.getElapsedTime() * SPEED);
		swingQuat.setFromAxisAngle(yAxis, swingAngle);
		roman.quaternion.copy(swingQuat).multiply(baseQuat);
	}

	controls.update(); // required for damping
	renderer.render(scene, camera);
});
</script>